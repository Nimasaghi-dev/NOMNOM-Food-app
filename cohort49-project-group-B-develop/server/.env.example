# Port the Express server listens on
PORT=3000

# MongoDB connection string from MongoDB Atlas (or local MongoDB)
# Replace <user>, <password>, <cluster>, and <dbName> with your own values
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?retryWrites=true&w=majority

# Secret key used to sign and verify JWT tokens — use a long random string (32+ characters)
TOKEN_KEY=replace_this_with_a_long_random_secret

# Secret used for Express session (needed for OAuth flows)
SESSION_SECRET=replace_this_with_another_long_random_secret

# Google OAuth credentials (only needed if you want Google login)
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL — used by CORS to allow requests from the React dev server
CLIENT_URL=http://localhost:8080

# Set to "production" when deploying to Heroku or another host
NODE_ENV=development

# For Cypress tests — use a separate database so tests never touch real data
# MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cypressDatabase?retryWrites=true&w=majority
